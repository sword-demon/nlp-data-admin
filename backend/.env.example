# ============================================================
# NLP Data Admin 环境变量模板
#
# 使用：cp .env.example .env  然后按需填写
# 所有敏感值（API Key / 密码 / JWT Secret）必须在生产环境替换
# ============================================================

# ===== 应用 =====
APP_NAME=nlp-data-admin
APP_ENV=dev                         # dev / prod
# APP_DEBUG=true

# ===== 数据库 MySQL =====
DB_DRIVER=mysql
DB_HOST=localhost                   # Docker 内部用 nlp-mysql
DB_PORT=3306
DB_DATABASE=nlp_content
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

# ===== Redis =====
REDIS_HOST=localhost                # Docker 内部用 nlp-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT =====
# 生成命令：php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_TTL=86400                       # 秒（1 天）
JWT_REFRESH_TTL=604800              # 秒（7 天）
JWT_ALGO=HS256

# ============================================================
# Phase 2/3 AI 模型（标题/大纲/正文/图片分析 Agent 共用）
# ============================================================
AI_PROVIDER=dashscope               # 可选：dashscope / openai

# -- 阿里云 DashScope（推荐，国内低延迟，兼容 OpenAI）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-plus           # qwen-plus / qwen-turbo / qwen3-plus

# -- OpenAI（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Phase 4 多策略配图系统
# ============================================================

# -- Pexels 真实图库（https://www.pexels.com/api/ ，免费 200 次/小时）
PEXELS_ENABLED=true
PEXELS_API_KEY=
PEXELS_LOCALE=zh-CN
PEXELS_ORIENTATION=landscape

# -- Mermaid 流程图（走 mermaid.ink 公共渲染服务，无需 Key）
MERMAID_ENABLED=true

# -- Iconify 图标（https://iconify.design ，无需 Key）
ICONIFY_ENABLED=true

# -- Emoji（Twemoji CDN，无需 Key）
EMOJI_ENABLED=true

# -- SVG 概念图（DashScope 生成，复用 DASHSCOPE_API_KEY）
SVG_ENABLED=true

# -- Nano Banana AI 生图（DashScope 万相文生图，仅付费会员可用）
NANOBANANA_ENABLED=true
NANOBANANA_MODEL=wanx2.1-t2i-turbo
NANOBANANA_SIZE=1024*768

# -- 阿里云 OSS 托管（不启用时图片直接返回源 URL）
OSS_ENABLED=false
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=
OSS_CDN_DOMAIN=                     # 可选：绑定 CDN 自定义域名
OSS_OBJECT_PREFIX=nlp/images

# -- 图片下载超时（秒）
IMAGE_FETCH_TIMEOUT=25

# ============================================================
# Phase 5 z-pay 聚合支付（https://z-pay.cn ，微信/支付宝扫码）
# ============================================================
ZPAY_PID=
ZPAY_KEY=
ZPAY_SUBMIT_URL=https://zpayz.cn/submit.php
ZPAY_API_URL=https://zpayz.cn/api.php
ZPAY_MAPI_URL=https://zpayz.cn/mapi.php
# 异步回调（公网可达；本地可用 ngrok/Cpolar 内穿）
ZPAY_NOTIFY_URL=http://localhost:9501/api/pay/notify
# 同步跳转（支付完成后浏览器跳回）
ZPAY_RETURN_URL=http://localhost:5173/vip/return
ZPAY_TIMEOUT=15

# ============================================================
# Phase 3.5 选题研究（Exa 搜索）
# https://exa.ai/docs/reference/search-api-guide
# 注意：值不能含空格 / 换行 / 中文等非法字符（phpdotenv 会报错）
# ============================================================
EXA_ENABLED=false                   # 未开启 / API Key 为空时 TopicResearchAgent 走降级
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_NUM_RESULTS=3                   # 单次检索条数，控制 Exa 成本
EXA_CACHE_TTL=86400                 # 研究结果缓存秒数（24h）
EXA_RATE_LIMIT_PER_SECOND=3         # 令牌桶：每秒最多调用次数

# ============================================================
# Phase 6 可观测性（默认使用数据库 AgentLog，无需额外配置）
# ============================================================
# 若后续接入 Prometheus/ELK，在此扩展
