APP_NAME=nlp-data-admin
APP_ENV=dev

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nlp_content
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT — generate via: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_TTL=86400
JWT_REFRESH_TTL=604800
JWT_ALGO=HS256

# AI Provider
AI_PROVIDER=dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===== 配图系统 (Phase 4) =====
PEXELS_ENABLED=true
PEXELS_API_KEY=
PEXELS_LOCALE=zh-CN
PEXELS_ORIENTATION=landscape

MERMAID_ENABLED=true
ICONIFY_ENABLED=true
EMOJI_ENABLED=true
SVG_ENABLED=true

NANOBANANA_ENABLED=true
NANOBANANA_MODEL=wanx2.1-t2i-turbo
NANOBANANA_SIZE=1024*768

OSS_ENABLED=false
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=
OSS_CDN_DOMAIN=
OSS_OBJECT_PREFIX=nlp/images

IMAGE_FETCH_TIMEOUT=25

# ===== Phase 5 z-pay 聚合支付 =====
# https://z-pay.cn/ 注册开通，支持微信/支付宝扫码
ZPAY_PID=
ZPAY_KEY=
ZPAY_SUBMIT_URL=https://zpayz.cn/submit.php
ZPAY_API_URL=https://zpayz.cn/api.php
ZPAY_MAPI_URL=https://zpayz.cn/mapi.php
# 异步回调 URL（必须公网可达；本地可用 ngrok）
ZPAY_NOTIFY_URL=http://localhost:9501/api/pay/notify
# 同步跳转 URL（支付完成后浏览器跳转）
ZPAY_RETURN_URL=http://localhost:5173/vip/return
ZPAY_TIMEOUT=15
